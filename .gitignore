__pycache__/
*.pyc
/tmp/
*.log
.DS_Store

# Large binary pipeline outputs — regenerate from scripts, not stored in git
runs/*/render/
runs/*/voice/*.mp3
runs/*/assets/ch*/

# Keep metadata/manifests/thumbnails in git
!runs/*/voice/manifest.json
!runs/*/assets/manifest.json
!runs/*/assets/ATTRIBUTION.md
!runs/*/thumb/

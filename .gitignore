__pycache__/
*.pyc
/tmp/
*.log
.DS_Store

# Large binary pipeline outputs — regenerate from scripts, not stored in git
runs/*/render/
runs/*/render/segments/*.mp4
runs/*/voice/*.mp3
runs/*/assets/ch*/
runs/*/assets/*.jpg
runs/*/assets/*.jpeg
runs/*/assets/*.png

# Bridged to YouTube via GitHub Release, not git history
runs/*/render/*.mp4

# Shorts cutter output — same policy as runs/*/render/: regenerate from the
# committed shorts/*.json config (short_cutter_v2.py), don't store in git.
# The .ass is a derived subtitle file, regenerated fresh from the config each run.
shorts/*.mp4
shorts/*.ass

# Keep metadata/manifests/thumbnails in git
!runs/*/voice/manifest.json
!runs/*/assets/manifest.json
!runs/*/assets/ATTRIBUTION.md
!runs/*/thumb/

# API keys (per source) — never commit
skills/long-form-pipeline/assets_library/api_keys.json
assets_packs/_archive/
# Uncompressed audio files (keep MP3 only)
assets_packs/**/*.wav
assets_packs/**/*.aiff
# Very large video B-roll (>10MB) — link via index only
# (individual files >10MB should be tracked via LFS or GitHub Release asset)
